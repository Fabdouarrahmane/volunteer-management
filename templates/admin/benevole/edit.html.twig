{% extends 'base.html.twig' %}

{% block title %}Modifier — {{ benevole.prenom }} {{ benevole.nom }}{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Modifier : {{ benevole.prenom }} {{ benevole.nom }}</h1>
        <a href="{{ path('app_admin_benevole_index') }}" class="btn btn-outline-secondary">← Retour</a>
    </div>

    <div class="alert alert-info">
        Laissez le mot de passe vide pour ne pas le modifier.
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            {{ include('admin/benevole/_form.html.twig', { button_label: 'Enregistrer' }) }}
        </div>
    </div>
{% endblock %}

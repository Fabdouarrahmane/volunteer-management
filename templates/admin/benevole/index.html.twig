{% extends 'base.html.twig' %}

{% block title %}Gestion des bénévoles{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Bénévoles</h1>
        <a href="{{ path('app_admin_benevole_new') }}" class="btn btn-primary">+ Nouveau bénévole</a>
    </div>

    {% if benevoles is empty %}
        <div class="alert alert-info">Aucun bénévole enregistré.</div>
    {% else %}
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                <tr>
                    <th>Nom</th>
                    <th>Prénom</th>
                    <th>Email</th>
                    <th>Téléphone</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for benevole in benevoles %}
                    <tr>
                        <td>{{ benevole.nom }}</td>
                        <td>{{ benevole.prenom }}</td>
                        <td>{{ benevole.email }}</td>
                        <td>{{ benevole.telephone }}</td>
                        <td>
                            <a href="{{ path('app_admin_benevole_show', {id: benevole.id}) }}" class="btn btn-sm btn-outline-info">Voir</a>
                            <a href="{{ path('app_admin_benevole_edit', {id: benevole.id}) }}" class="btn btn-sm btn-outline-warning">Modifier</a>
                            <form method="post" action="{{ path('app_admin_benevole_delete', {id: benevole.id}) }}" class="d-inline"
                                  onsubmit="return confirm('Supprimer ce bénévole ?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_benevole_' ~ benevole.id) }}">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Supprimer</button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
{% endblock %}

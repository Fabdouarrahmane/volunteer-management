{% extends 'base.html.twig' %}

{% block title %}Messagerie{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Messagerie</h1>
        <a href="{{ path('app_admin_dashboard') }}" class="btn btn-outline-secondary">← Retour</a>
    </div>

    {% if messages is empty %}
        <div class="alert alert-info">Aucun message échangé.</div>
    {% else %}
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                <tr>
                    <th>De</th>
                    <th>À</th>
                    <th>Sujet</th>
                    <th>Date</th>
                </tr>
                </thead>
                <tbody>
                {% for msg in messages %}
                    <tr>
                        <td>{{ msg.expediteur.prenom }} {{ msg.expediteur.nom }}</td>
                        <td>{{ msg.destinataire.prenom }} {{ msg.destinataire.nom }}</td>
                        <td>{{ msg.sujet }}</td>
                        <td>{{ msg.dateEnvoi|date('d/m/Y H:i') }}</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}{{ evenement.titre }}{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>{{ evenement.titre }}</h1>
        <a href="{{ path('app_benevole_evenement_index') }}" class="btn btn-outline-secondary">← Retour</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Description</dt>
                <dd class="col-sm-9">{{ evenement.description ?? '—' }}</dd>

                <dt class="col-sm-3">Date</dt>
                <dd class="col-sm-9">{{ evenement.dateEvenement|date('d/m/Y à H:i') }}</dd>

                <dt class="col-sm-3">Lieu</dt>
                <dd class="col-sm-9">{{ evenement.lieu ?? '—' }}</dd>

                <dt class="col-sm-3">Bénévoles requis</dt>
                <dd class="col-sm-9">{{ evenement.nbBenevoles }}</dd>
            </dl>
        </div>
    </div>
{% endblock %}

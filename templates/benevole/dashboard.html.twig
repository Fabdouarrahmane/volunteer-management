{% extends 'base.html.twig' %}

{% block title %}Mon espace bénévole{% endblock %}

{% block body %}
    <h1>Mon espace</h1>
    <p class="text-muted">Bienvenue, {{ app.user.prenom }} {{ app.user.nom }}</p>

    <div class="row mt-4">
        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-body">
                    <h5 class="card-title">📅 Mes disponibilités</h5>
                    <p class="card-text text-muted">Gérez vos plages horaires disponibles.</p>
                    <a href="#" class="btn btn-outline-primary btn-sm">Voir</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-body">
                    <h5 class="card-title">✅ Mes affectations</h5>
                    <p class="card-text text-muted">Consultez vos missions assignées.</p>
                    <a href="#" class="btn btn-outline-success btn-sm">Voir</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-body">
                    <h5 class="card-title">✉️ Messagerie</h5>
                    <p class="card-text text-muted">Consultez vos messages.</p>
                    <a href="#" class="btn btn-outline-info btn-sm">Voir</a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

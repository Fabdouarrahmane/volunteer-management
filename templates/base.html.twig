<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Volunteer Management{% endblock %}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.min.css">
    <style>
        .navbar-brand { font-weight: 600; letter-spacing: .3px; }
        .nav-link.active { font-weight: 600; }
        body { background-color: #f8f9fa; display: flex; flex-direction: column; min-height: 100vh; }
        main { flex: 1; }
        .footer-legal { font-size: .8rem; }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>

{% if app.user %}
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
        <div class="container">

            {# Brand #}
            {% if is_granted('ROLE_ADMIN') %}
                <a class="navbar-brand" href="{{ path('app_admin_dashboard') }}">
                    🤝 Volunteer Management
                </a>
            {% else %}
                <a class="navbar-brand" href="{{ path('app_benevole_dashboard') }}">
                    🤝 Volunteer Management
                </a>
            {% endif %}

            {# Toggler mobile #}
            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse" data-bs-target="#navbarMain"
                    aria-controls="navbarMain" aria-expanded="false" aria-label="Ouvrir le menu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarMain">

                {# ── Menu ADMIN ─────────────────────────────────────── #}
                {% if is_granted('ROLE_ADMIN') %}
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link {% if app.request.attributes.get('_route') == 'app_admin_dashboard' %}active{% endif %}"
                               href="{{ path('app_admin_dashboard') }}">
                                <i class="bi bi-speedometer2 me-1"></i>Tableau de bord
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_evenement' %}active{% endif %}"
                               href="{{ path('app_evenement_index') }}">
                                <i class="bi bi-calendar-event me-1"></i>Événements
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_admin_benevole' %}active{% endif %}"
                               href="{{ path('app_admin_benevole_index') }}">
                                <i class="bi bi-people me-1"></i>Bénévoles
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_affectation' %}active{% endif %}"
                               href="{{ path('app_affectation_index') }}">
                                <i class="bi bi-person-check me-1"></i>Affectations
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_admin_messagerie' %}active{% endif %}"
                               href="{{ path('app_admin_messagerie_index') }}">
                                <i class="bi bi-envelope me-1"></i>Messagerie
                            </a>
                        </li>
                    </ul>

                    {# ── Menu BÉNÉVOLE ───────────────────────────────────── #}
                {% else %}
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link {% if app.request.attributes.get('_route') == 'app_benevole_dashboard' %}active{% endif %}"
                               href="{{ path('app_benevole_dashboard') }}">
                                <i class="bi bi-house me-1"></i>Accueil
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_benevole_evenement' %}active{% endif %}"
                               href="{{ path('app_benevole_evenement_index') }}">
                                <i class="bi bi-calendar-event me-1"></i>Événements
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_disponibilite' %}active{% endif %}"
                               href="{{ path('app_disponibilite_index') }}">
                                <i class="bi bi-clock me-1"></i>Disponibilités
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link {% if app.request.attributes.get('_route') == 'app_benevole_affectation_index' %}active{% endif %}"
                               href="{{ path('app_benevole_affectation_index') }}">
                                <i class="bi bi-person-check me-1"></i>Mes affectations
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_message' %}active{% endif %}"
                               href="{{ path('app_message_index') }}">
                                <i class="bi bi-envelope me-1"></i>Messages
                            </a>
                        </li>
                    </ul>
                {% endif %}

                {# ── Dropdown utilisateur (commun) ───────────────────── #}
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle d-flex align-items-center gap-2"
                           href="#" role="button"
                           data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-person-circle fs-5"></i>
                            <span>{{ app.user.prenom }} {{ app.user.nom }}</span>
                            {% if is_granted('ROLE_ADMIN') %}
                                <span class="badge bg-danger ms-1">Admin</span>
                            {% else %}
                                <span class="badge bg-success ms-1">Bénévole</span>
                            {% endif %}
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow">
                            <li>
                                <a class="dropdown-item {% if app.request.attributes.get('_route') == 'app_profil' %}active{% endif %}"
                                   href="{{ path('app_profil') }}">
                                    <i class="bi bi-pencil-square me-2"></i>Mon profil
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item text-danger" href="{{ path('app_logout') }}">
                                    <i class="bi bi-box-arrow-right me-2"></i>Déconnexion
                                </a>
                            </li>
                        </ul>
                    </li>
                </ul>

            </div>{# /.navbar-collapse #}
        </div>{# /.container #}
    </nav>
{% endif %}

<main class="container mt-4">
    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>{{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
        </div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>{{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
        </div>
    {% endfor %}
    {% for message in app.flashes('warning') %}
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle me-2"></i>{{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
        </div>
    {% endfor %}

    {% block body %}{% endblock %}
</main>

<footer class="bg-dark text-white-50 py-3 mt-auto">
    <div class="container d-flex flex-column flex-sm-row justify-content-between align-items-center footer-legal">
        <span>© {{ "now"|date("Y") }} Volunteer Management — Projet Master 2</span>
        <span class="mt-2 mt-sm-0">
            <a href="{{ path('app_mentions_legales') }}" class="text-white-50 text-decoration-none me-3">Mentions légales</a>
            <a href="{{ path('app_politique_confidentialite') }}" class="text-white-50 text-decoration-none">Politique de confidentialité</a>
        </span>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>

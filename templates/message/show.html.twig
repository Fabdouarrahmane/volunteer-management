{% extends 'base.html.twig' %}

{% block title %}{{ message.sujet }}{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>{{ message.sujet }}</h1>
        <a href="{{ path('app_message_index') }}" class="btn btn-outline-secondary">← Retour</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-header">
            <div class="row">
                <div class="col-md-6">
                    <strong>De :</strong> {{ message.expediteur.prenom }} {{ message.expediteur.nom }}
                </div>
                <div class="col-md-6 text-end">
                    <strong>Date :</strong> {{ message.dateEnvoi|date('d/m/Y à H:i') }}
                </div>
            </div>
            <div>
                <strong>À :</strong> {{ message.destinataire.prenom }} {{ message.destinataire.nom }}
            </div>
        </div>
        <div class="card-body">
            <p>{{ message.contenu|nl2br }}</p>
        </div>
    </div>

    {% if message.expediteur == app.user %}
        <div class="mt-3">
            <form method="post" action="{{ path('app_message_delete', {id: message.id}) }}"
                  onsubmit="return confirm('Supprimer ce message ?')">
                <input type="hidden" name="_token" value="{{ csrf_token('delete_message_' ~ message.id) }}">
                <button type="submit" class="btn btn-outline-danger btn-sm">Supprimer</button>
            </form>
        </div>
    {% endif %}
{% endblock %}

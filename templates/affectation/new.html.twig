{% extends 'base.html.twig' %}

{% block title %}Nouvelle affectation{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Nouvelle affectation</h1>
        <a href="{{ path('app_affectation_index') }}" class="btn btn-outline-secondary">← Retour</a>
    </div>

    <div class="alert alert-info">
        Un email de notification sera automatiquement envoyé au bénévole lors de la création.
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            {{ include('affectation/_form.html.twig', { button_label: 'Créer l\'affectation' }) }}
        </div>
    </div>
{% endblock %}

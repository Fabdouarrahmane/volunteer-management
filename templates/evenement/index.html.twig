{% extends 'base.html.twig' %}

{% block title %}Événements{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Événements</h1>
        <a href="{{ path('app_evenement_new') }}" class="btn btn-primary">+ Nouvel événement</a>
    </div>

    {% if evenements is empty %}
        <div class="alert alert-info">Aucun événement pour le moment.</div>
    {% else %}
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                <tr>
                    <th>Titre</th>
                    <th>Date</th>
                    <th>Lieu</th>
                    <th>Bénévoles requis</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for evenement in evenements %}
                    <tr>
                        <td>{{ evenement.titre }}</td>
                        <td>{{ evenement.dateEvenement|date('d/m/Y H:i') }}</td>
                        <td>{{ evenement.lieu ?? '—' }}</td>
                        <td>{{ evenement.nbBenevoles }}</td>
                        <td>
                            {% set statut_colors = {
                                'planifie': 'primary',
                                'en_cours': 'warning',
                                'termine': 'success',
                                'annule': 'danger'
                            } %}
                            <span class="badge bg-{{ statut_colors[evenement.statutEvenement] ?? 'secondary' }}">
                            {{ evenement.statutEvenement }}
                        </span>
                        </td>
                        <td>
                            <a href="{{ path('app_evenement_show', {id: evenement.id}) }}" class="btn btn-sm btn-outline-info">Voir</a>
                            <a href="{{ path('app_evenement_edit', {id: evenement.id}) }}" class="btn btn-sm btn-outline-warning">Modifier</a>
                            <form method="post" action="{{ path('app_evenement_delete', {id: evenement.id}) }}" class="d-inline"
                                  onsubmit="return confirm('Supprimer cet événement ?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_evenement_' ~ evenement.id) }}">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Supprimer</button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
{% endblock %}
